set -euo pipefail

DU4_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
DU4_BIN_PATH="$DU4_ROOT/bin"

list_commands() {
  local file name
  for file in "$DU4_BIN_PATH"/du4*; do
    [ -f "$file" ] || continue
    [ -x "$file" ] || continue
    name="${file##*/du4}"
    name="${name%.sh}"
    name="${name%.bash}"
    printf '%s\n' "$name"
  done | sort -u
}

usage() {
  cat <<'EOF'
Usage: du4 <command> [args...]

Run "du4 help" to list available commands.
EOF
}

run_help() {
  echo "Available commands:"
  list_commands | sed 's/^/ - /'
  echo
  echo 'Tip: run "du4 <command> --help" for command-specific usage.'
}

resolve_bin() {
  local cmd="$1"
  local candidate
  for candidate in \
    "$DU4_BIN_PATH/du4$cmd" \
    "$DU4_BIN_PATH/du4$cmd.sh" \
    "$DU4_BIN_PATH/du4$cmd.bash"; do
    if [ -f "$candidate" ] && [ -x "$candidate" ]; then
      printf '%s\n' "$candidate"
      return 0
    fi
  done
  return 1
}

if [ "${1:-}" = "-h" ] || [ "${1:-}" = "--help" ] || [ $# -eq 0 ]; then
  usage
  echo
  run_help
  exit 0
fi

command="$1"
shift || true

if [ "$command" = "help" ]; then
  run_help
  exit 0
fi

if ! script_path="$(resolve_bin "$command")"; then
  echo "Error: unknown command '$command'." >&2
  echo >&2
  run_help >&2
  exit 1
fi

exec "$script_path" "$@"

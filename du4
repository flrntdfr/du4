set -euo pipefail

DU4_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
DU4_BIN_PATH="$DU4_ROOT/bin"
: "${DU4_VERBOSE:=0}"

du4_set_verbose() {
  DU4_VERBOSE="${1:-0}"
  export DU4_VERBOSE
}

log() {
  local stream="${1:-stdout}"
  shift || true
  case "$stream" in
    stdout)
      if [ "${DU4_VERBOSE:-0}" -eq 1 ]; then
        echo "$*"
      fi
      ;;
    stderr)
      echo "$*" >&2
      ;;
    *)
      echo "Error: invalid log stream '$stream'." >&2
      exit 1
      ;;
  esac
}

list_commands() {
  local file name
  for file in "$DU4_BIN_PATH"/du4*; do
    [ -f "$file" ] || continue
    [ -x "$file" ] || continue
    name="${file##*/du4}"
    name="${name%.sh}"
    name="${name%.bash}"
    printf '%s\n' "$name"
  done | sort -u
}

usage() {
  cat <<'EOF'
Usage: du4 [-v|--verbose] <command> [args...]

Run "du4 help" to list available commands.
EOF
}

run_help() {
  echo "Available commands:"
  list_commands | sed 's/^/ - /'
  echo
  echo 'Tip: run "du4 <command> --help" for command-specific usage.'
}

resolve_bin() {
  local cmd="$1"
  local candidate
  for candidate in \
    "$DU4_BIN_PATH/du4$cmd" \
    "$DU4_BIN_PATH/du4$cmd.sh" \
    "$DU4_BIN_PATH/du4$cmd.bash"; do
    if [ -f "$candidate" ] && [ -x "$candidate" ]; then
      printf '%s\n' "$candidate"
      return 0
    fi
  done
  return 1
}

du4_main() {
  if [ "${1:-}" = "-v" ] || [ "${1:-}" = "--verbose" ]; then
    du4_set_verbose 1
    shift
  fi

  if [ "${1:-}" = "-h" ] || [ "${1:-}" = "--help" ] || [ $# -eq 0 ]; then
    usage
    echo
    run_help
    return 0
  fi

  command="$1"
  shift || true

  if [ "$command" = "help" ]; then
    run_help
    return 0
  fi

  if ! script_path="$(resolve_bin "$command")"; then
    log stderr "Error: unknown command '$command'."
    log stderr ""
    run_help >&2
    return 1
  fi

  exec "$script_path" "$@"
}

if [[ "${BASH_SOURCE[0]}" == "$0" ]]; then
  du4_main "$@"
fi

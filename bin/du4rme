#!/bin/bash
# du4 rme command
# 2024

# ------------------------------------------------------------------------------
# Usage
# ------------------------------------------------------------------------------

# du4 rme <keep1> [keep2...] # Remove all files in the current directory except keep targets
# du4 rme *.log              # Removes all files except log files
# du4 rme --oops             # Revert files deleted from previous command using trash

# ------------------------------------------------------------------------------
# Config
# ------------------------------------------------------------------------------


DU4_RME_STATE_DIR=".du4/rme"
DU4_RME_LAST_DIR="$DU4_RME_STATE_DIR/last"

# ------------------------------------------------------------------------------
# Code
# ------------------------------------------------------------------------------

set -euo pipefail
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "$SCRIPT_DIR/../du4"

usage() {
  cat <<'EOF'
Usage:
  du4 rme [--dry-run] [--verbose] <keep1> [keep2...]
  du4 rme --oops

Behavior:
  - Removes all files/directories in the current directory except items listed.
  - Keep items can be explicit names or shell-style wildcard patterns (for example: "*.log").
  - Stores removed items under .du4/rme/last so they can be restored with --oops.
EOF
}

has_keep_match() {
  local keep_item="$1"

  if compgen -G -- "$keep_item" >/dev/null; then
    return 0
  fi
  if compgen -G -- "./$keep_item" >/dev/null; then
    return 0
  fi

  return 1
}

is_keep_item() {
  local item="$1"
  local keep_item
  for keep_item in "${KEEP_LIST[@]}"; do
    case "$item" in
      $keep_item)
        return 0
        ;;
    esac
  done
  return 1
}

restore_last() {
  if [ ! -d "$DU4_RME_LAST_DIR" ]; then
    log stderr "Error: nothing to restore (no $DU4_RME_LAST_DIR)."
    exit 1
  fi

  if ! find "$DU4_RME_LAST_DIR" -mindepth 1 -print -quit | grep -q .; then
    log stderr "Error: restore directory is empty."
    exit 1
  fi

  local item name target
  for item in "$DU4_RME_LAST_DIR"/*; do
    [ -e "$item" ] || continue
    name="$(basename "$item")"
    target="./$name"
    if [ -e "$target" ]; then
      log stderr "Error: cannot restore '$name' because it already exists."
      exit 1
    fi
    mv "$item" "$target"
    log stdout "Restored: $name"
  done

  rmdir "$DU4_RME_LAST_DIR" 2>/dev/null || true
  log stdout "Restore completed."
}

validate_keep_items() {
  local keep_item
  local missing=0

  for keep_item in "${KEEP_LIST[@]}"; do
    if has_keep_match "$keep_item"; then
      continue
    fi
    log stderr "Error: keep item '$keep_item' does not match any file in the current directory."
    missing=1
  done

  if [ "$missing" -ne 0 ]; then
    exit 1
  fi
}

remove_except() {
  rm -rf "$DU4_RME_LAST_DIR"
  mkdir -p "$DU4_RME_LAST_DIR"

  local removed_any=false
  local removed_count=0
  local entry base
  while IFS= read -r -d '' entry; do
    base="$(basename "$entry")"
    case "$base" in
      ".du4")
        continue
        ;;
    esac

    if is_keep_item "$base"; then
      log stdout "Keeping: $base"
      continue
    fi

    if [ "$DRY_RUN" = "true" ]; then
      log stdout "Would remove: $base"
      removed_any=true
      removed_count=$((removed_count + 1))
      continue
    fi

    mv "$entry" "$DU4_RME_LAST_DIR/"
    log stdout "Removed: $base"
    removed_any=true
    removed_count=$((removed_count + 1))
  done < <(find . -mindepth 1 -maxdepth 1 -print0)

  if [ "$DRY_RUN" = "true" ]; then
    rmdir "$DU4_RME_LAST_DIR" 2>/dev/null || true
    log stdout "Dry-run complete. $removed_count items would be removed."
  else
    if [ "$removed_any" = "false" ]; then
      rmdir "$DU4_RME_LAST_DIR" || true
      log stdout "No files removed."
    else
      log stdout "Removal completed. Run 'du4 rme --oops' to restore."
    fi
  fi
}

VERBOSE=false
DRY_RUN=false
DO_OOPS=false
KEEP_LIST=()

while [ $# -gt 0 ]; do
  case "$1" in
    help)
      usage
      exit 0
      ;;
    -v|--verbose)
      VERBOSE=true
      du4_set_verbose 1
      ;;
    -n|--dry-run)
      DRY_RUN=true
      ;;
    --oops)
      DO_OOPS=true
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    --)
      shift
      while [ $# -gt 0 ]; do
        KEEP_LIST+=("$(basename "$1")")
        shift
      done
      break
      ;;
    -*)
      log stderr "Error: unknown option '$1'."
      usage >&2
      exit 1
      ;;
    *)
      KEEP_LIST+=("$(basename "$1")")
      ;;
  esac
  shift
done

if [ "$DO_OOPS" = "true" ]; then
  if [ "${#KEEP_LIST[@]}" -gt 0 ]; then
    log stderr "Error: --oops cannot be combined with keep items."
    exit 1
  fi
  if [ "$DRY_RUN" = "true" ]; then
    log stderr "Error: --dry-run is not valid with --oops."
    exit 1
  fi
  restore_last
  exit 0
fi

if [ "${#KEEP_LIST[@]}" -eq 0 ]; then
  log stderr "Error: provide at least one item to keep."
  usage >&2
  exit 1
fi

validate_keep_items

remove_except
